# Copy this file to `.env` for local testing and fill in real values.
# In GitHub Actions, set these as repository secrets instead — never commit .env.

# Adzuna API credentials — register free at https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Gmail SMTP for sending the digest.
# Requires 2FA on the Gmail account + an App Password.
# Generate one at https://myaccount.google.com/apppasswords
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_TO=where_to_send_the_digest@example.com
